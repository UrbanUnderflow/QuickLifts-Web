WHOOP_SCOPES=offline,read:profile,read:body_measurement,read:cycles,read:recovery,read:sleep,read:workout

# Macra AppsFlyer raw Pull API sync. Keep the token server-side only.
APPSFLYER_RAW_DATA_API_TOKEN=

# Local-only: set to "true" in .env.local to bypass auth guards (e.g. AdminRouteGuard)
# while running the dev server. Hard-gated against production builds in code. Never set in prod.
NEXT_PUBLIC_DEV_AUTH_BYPASS=

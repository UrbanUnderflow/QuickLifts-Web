#!/usr/bin/env node
const fs = require('node:fs');

const getAgentName = () => {
  const candidates = [
    'AGENT_NAME',
    'VIRTUALOFFICE_AGENT',
    'QUICKLIFTS_AGENT',
    'GIT_AUTHOR_NAME',
    'GIT_COMMITTER_NAME',
    'USER',
    'USERNAME',
  ];

  for (const key of candidates) {
    const raw = process.env[key];
    if (typeof raw === 'string' && raw.trim()) {
      return raw.trim();
    }
  }

  return '';
};

const splitLines = (value) => value.replace(/\r\n/g, '\n').split('\n');

const toCommitText = (commitMsgPath, value) =>
  fs.writeFileSync(commitMsgPath, value.endsWith('\n') ? value : `${value}\n`);

const normalizeSubject = (subject, agentName) => {
  const trimmed = subject.trim();
  if (!trimmed) return subject;

  const hasPrefixTag = /^\[[^\]]+\]\s+/.test(trimmed);
  if (hasPrefixTag) {
    return subject;
  }

  const withoutPrefixTag = trimmed.replace(/^\[(?:agent:\s*)?[^\]]+\]\s*/i, '');
  const withoutSuffixTag = withoutPrefixTag.replace(/\s*\[(?:agent:\s*)?[^\]]+\]\s*$/i, '');
  const baseSubject = withoutSuffixTag.trim() || trimmed;
  return `[${agentName}] ${baseSubject}`;
};

const main = () => {
  const commitMsgPath = process.argv[2];
  if (!commitMsgPath || !fs.existsSync(commitMsgPath)) {
    return;
  }

  const messageText = fs.readFileSync(commitMsgPath, 'utf8');
  const rawLines = splitLines(messageText);

  const commentStart = rawLines.findIndex((line) => line.startsWith('#'));
  const commentLines = commentStart === -1 ? [] : rawLines.slice(commentStart);
  const nonCommentLines = commentStart === -1 ? rawLines.slice() : rawLines.slice(0, commentStart);

  if (nonCommentLines.length === 0) {
    return;
  }

  const agentName = getAgentName();
  if (!agentName) {
    return;
  }

  if (nonCommentLines[0].trim()) {
    nonCommentLines[0] = normalizeSubject(nonCommentLines[0], agentName);
  }

  const hasTrailer = nonCommentLines.some((line) => /^\s*Agent:\s*.+$/i.test(line));
  if (!hasTrailer) {
    while (nonCommentLines.length && nonCommentLines[nonCommentLines.length - 1].trim() === '') {
      nonCommentLines.pop();
    }
    nonCommentLines.push('', `Agent: ${agentName}`);
  }

  const rewritten = [...nonCommentLines, ...commentLines].join('\n');
  toCommitText(commitMsgPath, rewritten);
};

main();

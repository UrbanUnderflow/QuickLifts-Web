rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /simpbudget-users/{userId} {
      allow read, write: if isOwner(userId);

      match /budgetSpaces/{spaceId} {
        allow read, write: if isOwner(userId);
      }

      match /budgets/{budgetId} {
        allow read, write: if isOwner(userId);
      }

      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /pipeListShares/{shareId} {
      function isSharePathOwner() {
        return isSignedIn() && shareId.matches('^' + request.auth.uid + '-.*');
      }

      function isShareOwner() {
        return isSignedIn() && resource.data.ownerUid == request.auth.uid;
      }

      function isCreateOwner() {
        return isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      }

      function isInvitedEditor() {
        return isSignedIn()
          && resource.data.access == 'edit'
          && request.auth.token.email in resource.data.editorEmails;
      }

      function isAcceptingOwnInvite() {
        return isSignedIn()
          && request.auth.token.email != null
          && (
            request.auth.token.email in resource.data.viewerEmails
            || request.auth.token.email in resource.data.editorEmails
          )
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'inviteStatuses',
            'updatedAt'
          ])
          && request.resource.data.inviteStatuses
            .diff(resource.data.inviteStatuses)
            .affectedKeys()
            .hasOnly([request.auth.token.email])
          && request.resource.data.inviteStatuses[request.auth.token.email].email == request.auth.token.email
          && request.resource.data.inviteStatuses[request.auth.token.email].status == 'accepted';
      }

      allow read: if isSharePathOwner() || resource.data.publicRead == true || isShareOwner() || isInvitedEditor();
      allow create: if isCreateOwner();
      allow update: if isShareOwner()
        || isAcceptingOwnInvite()
        || (
          isInvitedEditor()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'list',
            'updatedAt',
            'lastEditedBy'
          ])
        );
      allow delete: if isShareOwner();
    }

    match /pipeLeadShares/{shareId} {
      function isLeadSharePathOwner() {
        return isSignedIn() && shareId.matches('^' + request.auth.uid + '-.*');
      }

      function isLeadShareOwner() {
        return isSignedIn() && resource.data.ownerUid == request.auth.uid;
      }

      function isLeadShareCreateOwner() {
        return isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      }

      allow read: if isLeadSharePathOwner() || resource.data.publicRead == true || isLeadShareOwner();
      allow create: if isLeadShareCreateOwner();
      allow update, delete: if isLeadShareOwner();
    }

    match /pipeListProfiles/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

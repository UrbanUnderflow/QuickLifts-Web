    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "test:unit:club-onboarding": "node --import tsx --test tests/unit/club-links.test.ts tests/unit/club-onboarding-routing.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:club-onboarding": "playwright test tests/e2e/creator-club-install.spec.ts",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:registry": "playwright test tests/e2e/registry-build-publish.spec.ts --workers=1",
    "test:e2e:registry:write": "PLAYWRIGHT_ALLOW_WRITE_TESTS=true playwright test tests/e2e/registry-build-publish.spec.ts --grep \"registry sync-state smoke\" --workers=1 --reporter=line",
    "test:e2e:pulsecheck:full": "playwright test tests/e2e/pulsecheck-onboarding-workspace.spec.ts tests/e2e/pulsecheck-athlete-journey.spec.ts tests/e2e/pulsecheck-protocol-practice-conversation.spec.ts --workers=1",
    "test:e2e:pulsecheck:pilot-dashboard": "playwright test tests/e2e/pulsecheck-pilot-dashboard.spec.ts --workers=1",
    "test:e2e:pulsecheck:write": "playwright test tests/e2e/pulsecheck-onboarding-workspace.spec.ts tests/e2e/pulsecheck-athlete-journey.spec.ts tests/e2e/pulsecheck-protocol-practice-conversation.spec.ts --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:auth": "node scripts/save-playwright-admin-storage-state.cjs",
    "test:e2e:bootstrap:check": "node scripts/check-playwright-bootstrap.cjs",
    "test:e2e:grant-admin": "node scripts/grant-dev-admin-from-playwright-state.cjs",
    "machine:setup:export": "node scripts/export-local-machine-setup.cjs",
    "machine:setup:import": "node scripts/import-local-machine-setup.cjs",
    "test:group-meet": "node --test tests/api/group-meet/*.test.cjs",
    "test:firebase-admin:runtime": "node --test tests/api/firebase-admin/*.runtime.test.cjs",
    "test:pulsecheck:repair": "node --test tests/api/pulsecheck/repair-daily-assignment.test.cjs",
    "test:pulsecheck:runtime": "node --test tests/api/pulsecheck/submit-pulsecheck-checkin.runtime.test.cjs tests/api/pulsecheck/pulsecheck-functions-proxy.runtime.test.cjs",
    "test:pulsecheck:gate": "node --test tests/api/pulsecheck/repair-daily-assignment.test.cjs tests/api/pulsecheck/submit-pulsecheck-checkin.runtime.test.cjs tests/api/pulsecheck/pulsecheck-functions-proxy.runtime.test.cjs",
    "smoke:pulsecheck:repair": "node scripts/pulsecheck-repair-smoke.cjs",
    "test:pulsecheck:predeploy": "npm run test:pulsecheck:gate && npm run smoke:pulsecheck:repair",
    "probe:pulsecheck:repair-live": "node scripts/probe-pulsecheck-repair-live.cjs",
    "repair:pulsecheck:general-invites": "node scripts/repairPulseCheckGeneralInviteStatuses.js",
    "audit:pulsecheck:ios-runtime": "node scripts/audit-pulsecheck-ios-runtime-live.cjs",
    "backfill:pulsecheck:ios-bridge": "node scripts/backfill-pulsecheck-ios-runtime-bridge.cjs",
    "agent:setup-hooks": "git config core.hooksPath .githooks",
    "agent:commit": "node scripts/agent-commit.js",
    "test:agent-outcomes": "node --test tests/api/agent/missionOsV2.runtime.test.cjs tests/api/agent/missionPlaybooks.runtime.test.cjs tests/api/agent/missionReadiness.runtime.test.cjs",
    "outcomes:backfill": "node scripts/backfillAgentOutcomes.js",
    "outcomes:backfill:dry": "node scripts/backfillAgentOutcomes.js --dry-run",
    "outcomes:replay": "node scripts/replayMissionOutcomeSummary.js",
    "outcomes:replay:dry": "node scripts/replayMissionOutcomeSummary.js --dry-run",
    "playbooks:backfill": "node scripts/backfillMissionPlaybooks.js --apply",
    "playbooks:backfill:dry": "node scripts/backfillMissionPlaybooks.js --dry-run",
    "playbooks:audit": "node scripts/auditMissionSideEffects.js",
    "playbooks:restart-canary": "node scripts/restartPulseCheckCoachLedCanary.js --apply",
    "playbooks:restart-canary:dry": "node scripts/restartPulseCheckCoachLedCanary.js --dry-run",
    "deliverables:backfill-reasons": "node scripts/backfillDeliverableReviewReasons.js --dry-run",
    "backfill:health-context": "node scripts/backfillHealthContext.js",
    "backfill:health-context:dry": "node scripts/backfillHealthContext.js --dry-run",
    "seed:health-context-mocks": "node scripts/seedHealthContextValidationMocks.js",
    "seed:health-context-mocks:dry": "node scripts/seedHealthContextValidationMocks.js --dry-run",
    "backfill:workout-count": "node scripts/backfillWorkoutCount.js",
    "backfill:workout-count:dry": "node scripts/backfillWorkoutCount.js --dry-run",
    "netlify-dev": "./node_modules/.bin/netlify dev --port 8888 --functions-port 9999 --offline",
    "dev:clean": "pkill -f \"node_modules/.bin/netlify dev --port 8888 --functions-port 9999\" || true && pkill -f \"netlify dev --port 8888 --functions-port 9999\" || true && pkill -f \"QuickLifts-Web/node_modules/.bin/next dev\" || true",
    "dev:fast": "bash scripts/dev-functions-link.sh && ./node_modules/.bin/netlify dev --port 8888 --functions-port 9999 -f netlify/functions-dev --offline",
    "dev:fast:clean": "npm run dev:clean && npm run dev:fast",
    "dev:fast:online": "bash scripts/dev-functions-link.sh && ./node_modules/.bin/netlify dev --port 8888 --functions-port 9999 -f netlify/functions-dev",
    "dev:full": "./node_modules/.bin/netlify dev --port 8888 --functions-port 9999 --offline",
    "dev:full:online": "./node_modules/.bin/netlify dev --port 8888 --functions-port 9999",
    "pulsecheckdemo:audio": "node scripts/generate-pulsecheckdemo-audio.js",
    "pulsecheckdemo:audio:ab": "node scripts/generate-pulsecheckdemo-audio.js --sample-only --all-profiles",

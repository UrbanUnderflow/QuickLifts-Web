  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "guard:firebase-admin": "node scripts/check-firebase-admin-guardrails.js",
    "audit:firebase-next-api": "node scripts/audit-firebase-next-api-runtime-risk.js",
    "audit:user-write-contract": "node scripts/verify-user-write-contract.js",

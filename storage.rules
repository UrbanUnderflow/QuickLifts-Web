rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasEmail() {
      return isAuthenticated() && request.auth.token.email != null;
    }

    function isAdminByClaim() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isAdminByFirestore() {
      return hasEmail()
        && firestore.get(/databases/(default)/documents/admin/$(request.auth.token.email)).data != null;
    }

    function isAdmin() {
      return isAdminByClaim() || isAdminByFirestore();
    }

    // Press kit assets should be public to view/download, but uploads must be restricted.
    match /press_assets/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Train Nora knowledge vault uploads. Files live under the owning coach's
    // uid; only that coach may write. Any signed-in user may read (e.g. a
    // linked athlete's Nora pulling shared context).
    match /coach-nora-vault/{coachId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == coachId;
    }

    // App sound-effect assets generated from /admin/ai-voice. Public
    // read (clients also use tokened downloadURLs); admin-only write.
    match /ritual-sfx/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pulsecheck-sfx/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for everything else (tight by default).
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
